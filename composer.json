{
    "name": "seu-usuario/php-mvc-skeleton",
    "description": "Skeleton MVC em PHP puro com Container, Repositórios e Tailwind CSS",
    "type": "project",
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
